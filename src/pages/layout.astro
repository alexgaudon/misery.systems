---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/services", label: "services" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>misery.systems</title>
    <meta name="description" content="misery.systems - my homelab" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/logo.png" as="image" />
    {currentPath === "/about" && <link rel="preload" href="/rack-min.jpg" as="image" />}
  </head>
  <body>
    <div class="container">
      <header>
        <img src="/logo.png" alt="misery.systems" class="logo" width="1072" height="256" />
        <p class="tagline">// a homelab</p>
      </header>

      <hr />

      <nav>
        {links.map((link, i) => (
          <Fragment>
            <a href={link.href} class={currentPath === link.href ? "active" : ""}>{link.label}</a>{i < links.length - 1 && <span class="sep">::</span>}
          </Fragment>
        ))}
      </nav>

      <hr />

      <main>
        <slot />
      </main>

      <hr />

      <footer>
        <div class="footer-links">
          <a href="https://github.com/AlexGaudon" target="_blank" rel="noopener noreferrer">[github]</a>
          <a href="mailto:alex@alexgaudon.dev">[email]</a>
          <a href="https://alexgaudon.dev" target="_blank" rel="noopener noreferrer">[main site]</a>
        </div>
        <p class="footer-note">not a cry for help. just a joke.</p>
      </footer>
    </div>
  </body>
</html>
